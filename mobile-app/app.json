{
  "expo": {
    "name": "mobile-app",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/plant-disease-logo.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/plant-disease-logo.png",
        "backgroundImage": "./assets/images/plant-disease-logo.png",
        "monochromeImage": "./assets/images/plant-disease-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.mobileapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/plant-disease-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/plant-disease-logo.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
